# Intuit Developer App Credentials
# Get these from https://developer.intuit.com/app/developer/dashboard
INTUIT_CLIENT_ID=your_client_id_here
INTUIT_CLIENT_SECRET=your_client_secret_here

# OAuth redirect URI — must match what's registered in your Intuit app settings
REDIRECT_URI=http://localhost:3000/callback

# App environment: 'sandbox' or 'production'
ENVIRONMENT=sandbox

# Express server
PORT=3000

# Session secret (any random string)
SESSION_SECRET=change_me_to_a_random_secret
